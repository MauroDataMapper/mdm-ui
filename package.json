{
  "name": "mdm-ui",
  "version": "7.4.0-SNAPSHOT",
  "engines": {
    "node": "18.19.0",
    "npm": "10.2.3"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "dist": "ng build --configuration production --output-path=dist/mdm-ui-$npm_package_version$([ -z \"$MDM_UI_THEME_NAME\" ] && echo \"\" || echo \"-$MDM_UI_THEME_NAME\") && npm run dist-archive",
    "dist-archive": "tar zcvf dist/mdm-ui-$npm_package_version$([ -z \"$MDM_UI_THEME_NAME\" ] && echo \"\" || echo \".$MDM_UI_THEME_NAME\").tgz -C dist mdm-ui-$npm_package_version$([ -z \"$MDM_UI_THEME_NAME\" ] && echo \"\" || echo \"-$MDM_UI_THEME_NAME\")",
    "test": "ng test",
    "test:watch": "ng test --watch",
    "test-clearCache": "ng test --clear-cache",
    "test-with-coverage": "ng test --coverage",
    "test-with-coverage-serial": "ng test --coverage --run-in-band",
    "lint": "ng lint",
    "eslint": "eslint . --fix",
    "eslint-sarif": "eslint . -f @microsoft/eslint-formatter-sarif -o eslint/eslint_report.sarif",
    "eslint-junit": "eslint . -f ./node_modules/eslint-junit/index.js -o eslint/eslint-junit.xml",
    "eslint-nofix": "eslint .",
    "eslint-report": "eslint . --format checkstyle -o eslint_report.json",
    "e2e": "ng e2e",
    "sonar": "sonar-scanner -Dsonar.projectVersion=$npm_package_version",
    "license-check": "license-check-and-add -f license-check-and-add-config.json",
    "pr-checks": "npm run license-check check && npm run eslint && npm run test"
  },
  "private": true,
  "eslint-junit": {
    "suiteName": "eslint tests",
    "output": "./eslint/eslint-junit.xml"
  },
  "dependencies": {
    "@ag-grid-community/angular": "31.0.3",
    "@ag-grid-community/client-side-row-model": "31.0.3",
    "@ag-grid-community/core": "31.0.3",
    "@ag-grid-community/styles": "31.0.3",
    "@angular/animations": "17.3.12",
    "@angular/cdk": "17.3.10",
    "@angular/common": "17.3.12",
    "@angular/core": "17.3.12",
    "@angular/flex-layout": "15.0.0-beta.42",
    "@angular/forms": "17.3.12",
    "@angular/material": "17.3.10",
    "@angular/platform-browser": "17.3.12",
    "@angular/platform-browser-dynamic": "17.3.12",
    "@bpmn-io/dmn-migrate": "0.4.3",
    "@ctrl/ngx-codemirror": "6.1.0",
    "@fortawesome/fontawesome-free": "5.15.4",
    "@joint/core": "^4.0.1",
    "@joint/layout-directed-graph": "^4.0.1",
    "@maurodatamapper/mdm-resources": "5.3.0",
    "@uirouter/angular": "13.0.0",
    "@uirouter/core": "6.1.0",
    "@uirouter/rx": "1.0.0",
    "@zxcvbn-ts/core": "3.0.4",
    "@zxcvbn-ts/language-en": "3.0.2",
    "angular-split": "17.1.1",
    "bootstrap": "5.3.3",
    "brace": "0.11.1",
    "chart.js": "4.4.9",
    "chartjs-plugin-datalabels": "2.2.0",
    "codemirror": "^5.65.16",
    "core-js": "3.27.2",
    "diff-match-patch": "1.0.5",
    "dmn-js": "10.1.0",
    "jodit": "4.6.2",
    "jszip": "3.10.1",
    "lodash": "4.17.21",
    "marked": "4.0.10",
    "ng2-charts": "6.0.1",
    "ngx-ace-wrapper": "16.0.0",
    "ngx-clipboard": "16.0.0",
    "ngx-image-cropper": "8.1.1",
    "ngx-jodit": "3.2.2",
    "ngx-json-viewer": "3.2.1",
    "ngx-skeleton-loader": "8.1.0",
    "ngx-toastr": "16.2.0",
    "prismjs": "1.30.0",
    "rxjs": "7.4.0",
    "svg-pan-zoom": "3.6.1",
    "zone.js": "0.14.10"
  },
  "overrides": {
    "ngx-jodit": {
      "rxjs": "$rxjs"
    }
  },
  "devDependencies": {
    "@angular-builders/custom-webpack": "17.0.2",
    "@angular-devkit/build-angular": "17.3.17",
    "@angular/cli": "^17.3.17",
    "@angular/compiler-cli": "17.3.12",
    "@microsoft/eslint-formatter-sarif": "3.1.0",
    "@types/diff-match-patch": "^1.0.32",
    "@types/jest": "27.5.2",
    "@types/lodash": "^4.14.161",
    "@types/marked": "^4.0.1",
    "@types/node": "18.19.105",
    "angular-password-strength-meter": "11.0.0",
    "babel-loader": "^8.2.3",
    "eslint": "8.57.1",
    "eslint-junit": "1.0.1",
    "file-saver": "2.0.5",
    "jest": "^29.7.0",
    "jest-html-reporter": "3.10.2",
    "jest-junit": "16.0.0",
    "jest-marbles": "^3.0.6",
    "jest-preset-angular": "14.0.0",
    "jest-sonar": "^0.2.16",
    "license-check-and-add": "4.0.5",
    "ng-mocks": "^14.12.1",
    "sonarqube-scanner": "^2.9.1",
    "ts-jest": "^29.1.2",
    "typescript": "5.4.5",
    "typescript-eslint": "^8.32.1"
  }
}
